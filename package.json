{
  "name": "signet-evm-program",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Solidity contract for requesting signatures from the SigNet MPC network, supporting simple signing and bidirectional cross-chain transactions",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm typecheck && pnpm test"
  },
  "license": "MIT",
  "devDependencies": {
    "@noble/curves": "^2.2.0",
    "@nomicfoundation/hardhat-ignition": "^3.0.2",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^24.0.0",
    "dotenv": "^17.4.2",
    "hardhat": "^3.9.0",
    "prettier": "^3.9.4",
    "prettier-plugin-solidity": "^2.3.1",
    "signet.js": "^0.4.2",
    "typescript": "~5.9.0",
    "viem": "^2.54.1"
  },
  "packageManager": "pnpm@10.29.3"
}
